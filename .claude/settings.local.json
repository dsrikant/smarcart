{
  "permissions": {
    "allow": [
      "Bash(npx expo*)",
      "Bash(npm install*)",
      "Bash(npm run*)",
      "Bash(git checkout*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push origin feature/*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(node*)",
      "Bash(npx tsc*)",
      "Bash(jest*)",
      "Bash(npm test:*)",
      "Bash(npx jest:*)",
      "Bash(node -e \"console.log\\(require\\(''./node_modules/react-native/package.json''\\).version\\)\")",
      "Bash(python3 -c \"import sys,json; d=json.load\\(sys.stdin\\); print\\(json.dumps\\({k:v for k,v in d.get\\(''''peerDependencies'''',{}\\).items\\(\\)}, indent=2\\)\\)\")",
      "Bash(ls *.d.ts)",
      "Bash(python3 -c \"import sys,json; d=json.load\\(sys.stdin\\); print\\(d.get\\(''''types'''',''''''''\\), d.get\\(''''typings'''',''''''''\\)\\)\")",
      "Bash(grep -l \"import { database } from ''@/db''\" src/hooks/*.ts)",
      "Bash(for f:*)",
      "Bash(do)",
      "Bash(sed -i '' \"s/import { database } from ''@\\\\/db'';/import database from ''@\\\\/db'';/\" \"$f\")",
      "Bash(done)",
      "Bash(git add:*)",
      "Bash(git push:*)",
      "Bash(brew install:*)"
    ],
    "deny": [
      "Bash(git push origin main)",
      "Bash(git push origin develop)",
      "Bash(git merge*)",
      "Bash(rm -rf*)",
      "Bash(curl*)",
      "Bash(wget*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/guard-main-branch.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash(git push*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/notify-pr-needed.sh"
          }
        ]
      }
    ]
  }
}
