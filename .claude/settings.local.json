{
  "permissions": {
    "allow": [
      "Bash(npx expo*)",
      "Bash(npm install*)",
      "Bash(npm run*)",
      "Bash(git checkout*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push origin feature/*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(node*)",
      "Bash(npx tsc*)",
      "Bash(jest*)"
    ],
    "deny": [
      "Bash(git push origin main)",
      "Bash(git push origin develop)",
      "Bash(git merge*)",
      "Bash(rm -rf*)",
      "Bash(curl*)",
      "Bash(wget*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/guard-main-branch.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash(git push*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/notify-pr-needed.sh"
          }
        ]
      }
    ]
  }
}